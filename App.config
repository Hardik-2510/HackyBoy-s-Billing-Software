<?xml version="1.0" encoding="utf-8" ?>
<configuration>
	<startup>
		<supportedRuntime version="v4.0" sku=".NETFramework,Version=v4.7.2" />
	</startup>

	<connectionStrings>
		<add name="connstrng" connectionString="Data Source=(localdb)\MSSQLLocalDB;Initial Catalog=HackyStore;Integrated Security=True;Persist Security Info=False;Pooling=False;MultipleActiveResultSets=False;Encrypt=True;TrustServerCertificate=False;Application Name=' SQL Server Management Studio';Command Timeout=0"/>
	</connectionStrings>
</configuration>